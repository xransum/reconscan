#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "==> pre-commit: ruff check"
uv run ruff check reconscan/ tests/

echo "==> pre-commit: ruff format --check"
uv run ruff format --check reconscan/ tests/

echo "==> pre-commit: mypy"
uv run mypy reconscan/ tests/

echo "==> pre-commit: next lint"
npm run lint --workspace=web

echo "==> pre-commit: prettier --check"
npm run format:check --workspace=web

echo "==> pre-commit: pytest"
uv run pytest

echo "==> pre-commit: jest"
npm test --workspace=web
