#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

BOLD=$(tput bold 2>/dev/null || true)
CYAN=$(tput setaf 6 2>/dev/null || true)
WHITE=$(tput setaf 7 2>/dev/null || true)
RESET=$(tput sgr0 2>/dev/null || true)

step() { echo "${BOLD}${CYAN}==>${RESET}${BOLD} ${WHITE}${1}${RESET}"; }

step "pre-commit: ruff check"
uv run ruff check reconscan/ tests/

step "pre-commit: ruff format --check"
uv run ruff format --check reconscan/ tests/

step "pre-commit: mypy"
uv run mypy reconscan/ tests/

step "pre-commit: next lint"
npm run lint --workspace=web

step "pre-commit: prettier --check"
npm run format:check --workspace=web

step "pre-commit: pytest"
uv run pytest

step "pre-commit: jest"
npm test --workspace=web
